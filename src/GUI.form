    <Component class="javax.swing.JButton" name="dltBTN">
      <Properties>
        <Property name="text" type="java.lang.String" value="Delete"/>
      </Properties>
      <Events>
        <EventHandler event="actionPerformed" listener="java.awt.event.ActionListener" parameters="java.awt.event.ActionEvent" handler="dltBTNActionPerformed"/>
      </Events>
      <AuxValues>
        <AuxValue name="JavaCodeGenerator_InitCodePost" type="java.lang.String" value="String idToDelete = idField.getText();&#xa;    &#xa;    if (idToDelete.isEmpty()) {&#xa;        javax.swing.JOptionPane.showMessageDialog(this, &quot;Please enter a Report ID to delete.&quot;);&#xa;        return;&#xa;    }&#xa;&#xa;    // Attempt to delete&#xa;    boolean success = masterList.deleteByID(idToDelete);&#xa;&#xa;    if (success) {&#xa;        javax.swing.JOptionPane.showMessageDialog(this, &quot;Report &quot; + idToDelete + &quot; deleted successfully.&quot;);&#xa;        &#xa;        // REFRESH the display so the user sees it&apos;s gone&#xa;        displayArea.setText(masterList.getAllReports());&#xa;        &#xa;        // Clear the fields&#xa;        idField.setText(&quot;&quot;);&#xa;        locField.setText(&quot;&quot;);&#xa;    } else {&#xa;        javax.swing.JOptionPane.showMessageDialog(this, &quot;Could not find Report ID: &quot; + idToDelete);&#xa;    }"/>
      </AuxValues>
    </Component>
